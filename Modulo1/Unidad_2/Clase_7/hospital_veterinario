    # 2. Registramos dos mascotas
    mascota1 = Mascota("Firulais", "Perro", 5, 10)
    mascota2 = Mascota("Tom", "Gato", 3, 4)

    cliente.agregar_mascota(mascota1)
    cliente.agregar_mascota(mascota2)

    # 3. Creamos un veterinario
    veterinario = Veterinario("Dr. Carlos", "4213", "Cirugía")

    # 4. Creamos una consulta
    consulta = Consulta(mascota1, veterinario, "Dolor", "Infección")

    # 5. La consulta genera dos tratamientos
    t1 = Tratamiento("Antibiótico", 50000, 5)
    t2 = Tratamiento("Vitaminas", 30000, 10)

    consulta.crear_tratamiento(t1)
    consulta.crear_tratamiento(t2)

    # Mostrar Resumen
    consulta.mostrar_resumen()

    # 6. Generar factura y calcular total
    factura = Factura(consulta)
    factura.calcular_total()
    factura.mostrar_factura()

    # 7. Se paga con un método de pago
    pago1 = PagoEfectivo()
    print(factura.pagar(pago1))
    print("─" * 60)

    # 8. Se cambia el método de pago
    pago2 = PagoTarjeta()
    print("Cambió método de pago")
    print(factura.pagar(pago2))
    print("─" * 60)